{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://exochain.dev/schemas/c2/attention-item.schema.json",
  "title": "PresidentialAttentionItem",
  "type": "object",
  "required": ["decision_id", "mission_node_id", "council_receipt_id", "advisory_receipts", "dissent_receipt_id", "recommended_action"],
  "properties": {
    "decision_id": { "type": "string", "minLength": 1 },
    "mission_node_id": { "type": "string", "minLength": 1 },
    "summary": { "type": "string" },
    "council_receipt_id": { "type": "string", "minLength": 1 },
    "advisory_receipts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["provider", "model_id", "role", "response_hash"],
        "properties": {
          "provider": { "type": "string" },
          "model_id": { "type": "string" },
          "role": { "type": "string" },
          "response_hash": { "type": "string", "minLength": 1 }
        }
      }
    },
    "dissent_receipt_id": { "type": "string", "minLength": 1 },
    "crosscheck_aggregate_hash": { "type": "string" },
    "recommended_action": { "enum": ["inquire", "challenge", "ratify", "veto"] },
    "requires_two_person_gate": { "type": "boolean" }
  },
  "additionalProperties": false
}
