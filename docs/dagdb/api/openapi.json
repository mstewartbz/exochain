{
  "openapi": "3.1.0",
  "info": {
    "title": "ExoChain DAG DB HTTP API",
    "version": "1.0.0",
    "description": "Machine contract for the governed agent-memory DAG DB HTTP surface served under /api/v1/dag-db. Every response schema carries a stable `schema_version` const so a non-Rust integrator can detect the wire-contract version directly from a response body. This document is the single artifact a non-Rust consumer codegens from. It is generated-by-hand from the `exo-api` Rust DTOs (crates/exo-api/src/dagdb.rs) and CI-asserted to stay in sync by the `openapi_spec_matches_dtos` test in crates/exo-api/tests/openapi_sync.rs (every response fixture in crates/exo-dag-db-api/fixtures/json/all_dto_fixtures.json validates against the matching response schema here, and each documented `schema_version` const equals the Rust constant). Response DTOs are strict: `additionalProperties: false` mirrors `#[serde(deny_unknown_fields)]`.",
    "license": { "name": "Apache-2.0", "identifier": "Apache-2.0" }
  },
  "servers": [
    { "url": "/api/v1/dag-db", "description": "DAG DB REST prefix for the gateway runtime; functional persistence requires a configured Postgres pool plus tenant/session authority, and missing runtime state fails closed." }
  ],
  "paths": {
    "/route": {
      "post": {
        "summary": "Create a governed retrieval route.",
        "operationId": "dagDbRoute",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DagDbRouteRequest" } } } },
        "responses": {
          "200": { "description": "Route created.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DagDbRouteResponse" } } } },
          "default": { "description": "Error envelope.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DagDbErrorEnvelope" } } } }
        }
      }
    },
    "/context-packet": {
      "post": {
        "summary": "Build a bounded, governed context packet for a task.",
        "operationId": "dagDbContextPacket",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DagDbContextPacketRequest" } } } },
        "responses": {
          "200": { "description": "Context packet built.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DagDbContextPacketResponse" } } } },
          "default": { "description": "Error envelope.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DagDbErrorEnvelope" } } } }
        }
      }
    },
    "/writeback": {
      "post": {
        "summary": "Write back an agent answer as a governed memory.",
        "operationId": "dagDbWriteback",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DagDbWritebackRequest" } } } },
        "responses": {
          "200": { "description": "Writeback recorded.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DagDbWritebackResponse" } } } },
          "default": { "description": "Error envelope.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DagDbErrorEnvelope" } } } }
        }
      }
    },
    "/import": {
      "post": {
        "summary": "Import a dry-run knowledge-graph batch into the governed store.",
        "operationId": "dagDbImport",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DagDbImportRequest" } } } },
        "responses": {
          "200": { "description": "Import recorded.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DagDbImportResponse" } } } },
          "default": { "description": "Error envelope.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DagDbErrorEnvelope" } } } }
        }
      }
    },
    "/export": {
      "post": {
        "summary": "Export a governed knowledge-graph slice.",
        "operationId": "dagDbExport",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DagDbExportRequest" } } } },
        "responses": {
          "200": { "description": "Export built.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DagDbExportResponse" } } } },
          "default": { "description": "Error envelope.", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/DagDbErrorEnvelope" } } } }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "SafeMetadataDecision": { "type": "string", "enum": ["allow", "redact", "reject"] },
      "RedactionCode": { "type": "string", "enum": ["ssn", "card", "confidential_marker", "phi", "customer_private", "code_excerpt", "length_truncation"] },
      "ValidationStatus": { "type": "string", "enum": ["not_required", "pending", "passed", "failed", "contradictory", "expired", "needs_council"] },
      "CouncilReviewStatus": { "type": "string", "enum": ["not_required", "required", "pending", "approved", "denied", "expired", "escalated"] },
      "DagFinalityStatus": { "type": "string", "enum": ["pending", "committed", "failed", "compensated"] },
      "RouteStatus": { "type": "string", "enum": ["pending", "active", "stale", "invalidated", "blocked"] },
      "RiskClass": { "type": "string", "enum": ["R0", "R1", "R2", "R3", "R4", "R5"] },
      "SubjectKind": { "type": "string", "enum": ["memory", "catalog", "route", "context_packet", "validation_report", "agent_safety_score", "inbound_agent_credential", "council_decision"] },
      "ValidationDecision": { "type": "string", "enum": ["allow", "block", "needs_council", "invalidate", "revoke", "supersede"] },
      "CredentialStatus": { "type": "string", "enum": ["pending", "active", "expired", "revoked", "blocked"] },
      "CouncilDecisionStatus": { "type": "string", "enum": ["approved", "denied", "expired", "escalated", "revoked"] },
      "ReceiptEventType": { "type": "string", "enum": ["intake_created", "duplicate_rejected", "validation_created", "validation_passed", "validation_failed", "memory_approved", "memory_routable", "memory_revoked", "memory_superseded", "route_created", "route_activated", "route_stale", "route_invalidated", "context_packet_created", "writeback_created", "trust_check_created", "council_decision_recorded", "dag_finality_committed", "dag_finality_failed", "dag_finality_compensated"] },
      "MemoryStatus": { "type": "string", "enum": ["pending", "approved", "routable", "blocked", "revoked", "superseded", "rejected"] },
      "MemoryEdgeKind": { "type": "string", "enum": ["derived_from", "summarizes", "supports", "contradicts", "supersedes", "replaces", "duplicate_of", "near_duplicate_of", "related_to", "alternative_summary_of", "depends_on", "part_of", "owned_by", "access_granted_by", "verified_by", "used_by_route", "included_in_context_packet", "revoked_by"] },
      "MemoryGraphStyle": { "type": "string", "enum": ["provenance_receipt_dag", "canonical_memory_graph", "semantic_catalog_graph", "similarity_overlay_graph", "dependency_dag", "routing_view_graph", "contradiction_supersession_graph", "context_packet_graph"] },

      "SafeMetadata": {
        "type": "object",
        "additionalProperties": false,
        "required": ["decision", "text", "redaction_codes", "original_hash", "truncated", "byte_len"],
        "properties": {
          "decision": { "$ref": "#/components/schemas/SafeMetadataDecision" },
          "text": { "type": "string" },
          "redaction_codes": { "type": "array", "items": { "$ref": "#/components/schemas/RedactionCode" } },
          "original_hash": { "type": "string" },
          "truncated": { "type": "boolean" },
          "byte_len": { "type": "integer", "minimum": 0 }
        }
      },
      "ContextPacketMemoryRef": {
        "type": "object",
        "additionalProperties": false,
        "required": ["memory_id", "title", "summary", "keywords", "latest_receipt_hash"],
        "properties": {
          "memory_id": { "type": "string" },
          "title": { "$ref": "#/components/schemas/SafeMetadata" },
          "summary": { "$ref": "#/components/schemas/SafeMetadata" },
          "keywords": { "type": "array", "items": { "$ref": "#/components/schemas/SafeMetadata" } },
          "latest_receipt_hash": { "type": "string" }
        }
      },
      "ContextPacketLayerRef": {
        "type": "object",
        "additionalProperties": false,
        "required": ["layer_id", "layer_path", "layer_depth", "layer_kind", "selected_ref_count"],
        "properties": {
          "layer_id": { "type": "string" },
          "layer_path": { "type": "string" },
          "layer_depth": { "type": "integer", "minimum": 0 },
          "layer_kind": { "type": "string" },
          "selected_ref_count": { "type": "integer", "minimum": 0 }
        }
      },
      "ContextPacketLayerEdgeRef": {
        "type": "object",
        "additionalProperties": false,
        "required": ["layer_edge_id", "from_layer_id", "to_layer_id", "edge_kind"],
        "properties": {
          "layer_edge_id": { "type": "string" },
          "from_layer_id": { "type": "string" },
          "to_layer_id": { "type": "string" },
          "edge_kind": { "type": "string" }
        }
      },
      "ContextPacketLayerBudgetReport": {
        "type": "object",
        "additionalProperties": false,
        "required": ["layered_mode", "max_layer_depth", "required_layer_evidence", "budget_status"],
        "properties": {
          "layered_mode": { "type": "string" },
          "max_layer_depth": { "type": "integer", "minimum": 0 },
          "required_layer_evidence": { "type": "boolean" },
          "budget_status": { "type": "string" }
        }
      },
      "DagDbSelectedGraphEdgeRef": {
        "type": "object",
        "additionalProperties": false,
        "required": ["graph_edge_id", "from_memory_id", "to_memory_id", "edge_kind", "graph_style", "selection_reason"],
        "properties": {
          "graph_edge_id": { "type": "string" },
          "from_memory_id": { "type": "string" },
          "to_memory_id": { "type": "string" },
          "edge_kind": { "$ref": "#/components/schemas/MemoryEdgeKind" },
          "graph_style": { "$ref": "#/components/schemas/MemoryGraphStyle" },
          "selection_reason": { "type": "string" }
        }
      },
      "DagDbContextPacketCitationRef": {
        "type": "object",
        "additionalProperties": false,
        "required": ["citation_ref", "memory_id", "citation_status"],
        "properties": {
          "citation_ref": { "type": "string" },
          "memory_id": { "type": "string" },
          "citation_status": { "type": "string" }
        }
      },
      "DagDbContextPacketMetrics": {
        "type": "object",
        "additionalProperties": false,
        "required": ["token_budget", "selected_token_estimate", "selected_memory_ref_count", "selected_graph_edge_count", "citation_ref_count", "end_to_end_savings_status", "cost_savings_status"],
        "properties": {
          "token_budget": { "type": "integer", "minimum": 0 },
          "selected_token_estimate": { "type": "integer", "minimum": 0 },
          "selected_memory_ref_count": { "type": "integer", "minimum": 0 },
          "selected_graph_edge_count": { "type": "integer", "minimum": 0 },
          "citation_ref_count": { "type": "integer", "minimum": 0 },
          "end_to_end_savings_status": { "type": "string" },
          "cost_savings_status": { "type": "string" }
        }
      },
      "DagDbContextPacketBoundaries": {
        "type": "object",
        "additionalProperties": false,
        "required": ["repository_test_level_only", "production_runtime", "default_context_replacement", "citation_locator_status", "billing_savings"],
        "properties": {
          "repository_test_level_only": { "type": "boolean" },
          "production_runtime": { "type": "string" },
          "default_context_replacement": { "type": "string" },
          "citation_locator_status": { "type": "string" },
          "billing_savings": { "type": "string" }
        }
      },
      "CatalogEntryResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["catalog_id", "title", "summary"],
        "properties": {
          "catalog_id": { "type": "string" },
          "title": { "$ref": "#/components/schemas/SafeMetadata" },
          "summary": { "$ref": "#/components/schemas/SafeMetadata" }
        }
      },

      "DagDbErrorEnvelope": {
        "type": "object",
        "additionalProperties": false,
        "required": ["error_code", "message", "requires_council_review"],
        "properties": {
          "error_code": { "type": "string" },
          "message": { "type": "string" },
          "receipt_hash": { "type": ["string", "null"] },
          "validation_report_id": { "type": ["string", "null"] },
          "requires_council_review": { "type": "boolean" }
        }
      },

      "DagDbIntakeRequest": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tenant_id", "namespace", "idempotency_key", "source_type", "source_hash", "payload_hash", "owner_did", "controller_did", "submitted_by_did", "consent_purpose", "requested_action", "title_text", "summary_text"],
        "properties": {
          "tenant_id": { "type": "string" },
          "namespace": { "type": "string" },
          "idempotency_key": { "type": "string" },
          "source_type": { "type": "string", "enum": ["public_web", "private_customer", "ip_sensitive", "generated", "open_source", "unknown_provenance", "benchmark_fixture"] },
          "source_hash": { "type": "string" },
          "payload_hash": { "type": "string" },
          "owner_did": { "type": "string" },
          "controller_did": { "type": "string" },
          "submitted_by_did": { "type": "string" },
          "consent_purpose": { "type": "string", "enum": ["retrieval", "validation", "writeback", "benchmark", "trust_check"] },
          "requested_action": { "type": "string" },
          "title_text": { "type": "string" },
          "summary_text": { "type": "string" },
          "payload_uri_hash": { "type": ["string", "null"] },
          "parent_memory_ids": { "type": ["array", "null"], "items": { "type": "string" } },
          "edge_types": { "type": ["array", "null"], "items": { "type": "string" } },
          "access_policy_hash": { "type": ["string", "null"] },
          "declared_rights_hash": { "type": ["string", "null"] },
          "keyword_texts": { "type": ["array", "null"], "items": { "type": "string" } }
        }
      },

      "DagDbIntakeResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["schema_version", "tenant_id", "namespace", "idempotency_key", "memory_id", "receipt_hash", "validation_status", "council_status", "dag_finality_status", "risk_class", "risk_bp", "created_new", "title", "summary", "keywords"],
        "properties": {
          "schema_version": { "type": "string", "const": "dagdb_intake_response_v1" },
          "tenant_id": { "type": "string" },
          "namespace": { "type": "string" },
          "idempotency_key": { "type": "string" },
          "memory_id": { "type": "string" },
          "receipt_hash": { "type": "string" },
          "validation_status": { "$ref": "#/components/schemas/ValidationStatus" },
          "council_status": { "$ref": "#/components/schemas/CouncilReviewStatus" },
          "dag_finality_status": { "$ref": "#/components/schemas/DagFinalityStatus" },
          "risk_class": { "$ref": "#/components/schemas/RiskClass" },
          "risk_bp": { "type": "integer", "minimum": 0 },
          "created_new": { "type": "boolean" },
          "title": { "$ref": "#/components/schemas/SafeMetadata" },
          "summary": { "$ref": "#/components/schemas/SafeMetadata" },
          "keywords": { "type": "array", "items": { "$ref": "#/components/schemas/SafeMetadata" } },
          "validation_report_id": { "type": ["string", "null"] },
          "council_decision_id": { "type": ["string", "null"] },
          "duplicate_of_memory_id": { "type": ["string", "null"] }
        }
      },

      "DagDbRouteResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["schema_version", "tenant_id", "namespace", "idempotency_key", "route_id", "receipt_hash", "validation_status", "council_status", "route_status", "dag_finality_status", "selected_memory_ids", "route_score_bp", "token_budget", "token_estimate", "stale_at", "created_new"],
        "properties": {
          "schema_version": { "type": "string", "const": "dagdb_route_response_v1" },
          "tenant_id": { "type": "string" },
          "namespace": { "type": "string" },
          "idempotency_key": { "type": "string" },
          "route_id": { "type": "string" },
          "receipt_hash": { "type": "string" },
          "validation_status": { "$ref": "#/components/schemas/ValidationStatus" },
          "council_status": { "$ref": "#/components/schemas/CouncilReviewStatus" },
          "route_status": { "$ref": "#/components/schemas/RouteStatus" },
          "dag_finality_status": { "$ref": "#/components/schemas/DagFinalityStatus" },
          "selected_memory_ids": { "type": "array", "items": { "type": "string" } },
          "route_score_bp": { "type": "integer", "minimum": 0 },
          "token_budget": { "type": "integer", "minimum": 0 },
          "token_estimate": { "type": "integer", "minimum": 0 },
          "stale_at": { "type": "string" },
          "created_new": { "type": "boolean" },
          "validation_report_id": { "type": ["string", "null"] },
          "council_decision_id": { "type": ["string", "null"] },
          "rejected_memory_ids": { "type": ["array", "null"], "items": { "type": "string" } }
        }
      },

      "DagDbContextPacketResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["schema_version", "tenant_id", "namespace", "idempotency_key", "context_packet_id", "route_id", "receipt_hash", "validation_status", "council_status", "dag_finality_status", "memory_refs", "packet_hash", "token_budget", "token_estimate", "created_new"],
        "properties": {
          "schema_version": { "type": "string", "const": "dagdb_context_packet_response_v1" },
          "tenant_id": { "type": "string" },
          "namespace": { "type": "string" },
          "idempotency_key": { "type": "string" },
          "context_packet_id": { "type": "string" },
          "route_id": { "type": "string" },
          "receipt_hash": { "type": "string" },
          "validation_status": { "$ref": "#/components/schemas/ValidationStatus" },
          "council_status": { "$ref": "#/components/schemas/CouncilReviewStatus" },
          "dag_finality_status": { "$ref": "#/components/schemas/DagFinalityStatus" },
          "memory_refs": { "type": "array", "items": { "$ref": "#/components/schemas/ContextPacketMemoryRef" } },
          "packet_hash": { "type": "string" },
          "token_budget": { "type": "integer", "minimum": 0 },
          "token_estimate": { "type": "integer", "minimum": 0 },
          "created_new": { "type": "boolean" },
          "validation_report_id": { "type": ["string", "null"] },
          "council_decision_id": { "type": ["string", "null"] },
          "context_packet_mode": { "type": "string" },
          "selection_warning": { "type": "string" },
          "layered_mode": { "type": "string" },
          "selected_layers": { "type": "array", "items": { "$ref": "#/components/schemas/ContextPacketLayerRef" } },
          "selected_layer_edges": { "type": "array", "items": { "$ref": "#/components/schemas/ContextPacketLayerEdgeRef" } },
          "layer_budget_report": { "$ref": "#/components/schemas/ContextPacketLayerBudgetReport" },
          "flat_fallback_used": { "type": "boolean" },
          "layered_status": { "type": "string" },
          "selected_graph_edges": { "type": "array", "items": { "$ref": "#/components/schemas/DagDbSelectedGraphEdgeRef" } },
          "citation_refs": { "type": "array", "items": { "$ref": "#/components/schemas/DagDbContextPacketCitationRef" } },
          "packet_metrics": { "$ref": "#/components/schemas/DagDbContextPacketMetrics" },
          "boundaries": { "$ref": "#/components/schemas/DagDbContextPacketBoundaries" },
          "packet_markdown": { "type": "string" }
        }
      },

      "DagDbValidateResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["schema_version", "tenant_id", "namespace", "idempotency_key", "validation_report_id", "subject_kind", "subject_id", "receipt_hash", "validation_status", "council_status", "risk_class", "risk_bp", "decision", "created_new"],
        "properties": {
          "schema_version": { "type": "string", "const": "dagdb_validate_response_v1" },
          "tenant_id": { "type": "string" },
          "namespace": { "type": "string" },
          "idempotency_key": { "type": "string" },
          "validation_report_id": { "type": "string" },
          "subject_kind": { "$ref": "#/components/schemas/SubjectKind" },
          "subject_id": { "type": "string" },
          "receipt_hash": { "type": "string" },
          "validation_status": { "$ref": "#/components/schemas/ValidationStatus" },
          "council_status": { "$ref": "#/components/schemas/CouncilReviewStatus" },
          "risk_class": { "$ref": "#/components/schemas/RiskClass" },
          "risk_bp": { "type": "integer", "minimum": 0 },
          "decision": { "$ref": "#/components/schemas/ValidationDecision" },
          "created_new": { "type": "boolean" },
          "council_decision_id": { "type": ["string", "null"] },
          "contradictory_report_ids": { "type": ["array", "null"], "items": { "type": "string" } },
          "notes": { "oneOf": [ { "$ref": "#/components/schemas/SafeMetadata" }, { "type": "null" } ] }
        }
      },

      "DagDbWritebackResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["schema_version", "tenant_id", "namespace", "idempotency_key", "memory_id", "receipt_hash", "validation_status", "council_status", "dag_finality_status", "risk_class", "risk_bp", "created_new"],
        "properties": {
          "schema_version": { "type": "string", "const": "dagdb_writeback_response_v1" },
          "tenant_id": { "type": "string" },
          "namespace": { "type": "string" },
          "idempotency_key": { "type": "string" },
          "memory_id": { "type": "string" },
          "receipt_hash": { "type": "string" },
          "validation_status": { "$ref": "#/components/schemas/ValidationStatus" },
          "council_status": { "$ref": "#/components/schemas/CouncilReviewStatus" },
          "dag_finality_status": { "$ref": "#/components/schemas/DagFinalityStatus" },
          "risk_class": { "$ref": "#/components/schemas/RiskClass" },
          "risk_bp": { "type": "integer", "minimum": 0 },
          "created_new": { "type": "boolean" },
          "validation_report_id": { "type": ["string", "null"] },
          "council_decision_id": { "type": ["string", "null"] },
          "summary": { "oneOf": [ { "$ref": "#/components/schemas/SafeMetadata" }, { "type": "null" } ] },
          "keywords": { "type": ["array", "null"], "items": { "$ref": "#/components/schemas/SafeMetadata" } },
          "target_layer_path": { "type": "string" },
          "target_layer_depth": { "type": "integer", "minimum": 0 },
          "target_layer_reason": { "type": "string" },
          "created_child_layer_id": { "type": "string" },
          "layered_writeback_status": { "type": "string" }
        }
      },

      "DagDbImportResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["schema_version", "operation_id", "tenant_id", "namespace", "idempotency_key", "db_set_version", "import_status", "source_hash", "imported_record_count", "non_claims"],
        "properties": {
          "schema_version": { "type": "string", "const": "dagdb_import_response_v1" },
          "operation_id": { "type": "string" },
          "tenant_id": { "type": "string" },
          "namespace": { "type": "string" },
          "idempotency_key": { "type": "string" },
          "db_set_version": { "type": "string" },
          "import_status": { "type": "string" },
          "import_receipt_id": { "type": ["string", "null"] },
          "source_hash": { "type": "string" },
          "imported_record_count": { "type": "integer", "minimum": 0 },
          "receipt_path": { "type": ["string", "null"] },
          "non_claims": { "type": "array", "items": { "type": "string" } }
        }
      },

      "DagDbExportResponse": {
        "type": "object",
        "additionalProperties": false,
        "required": ["schema_version", "operation_id", "tenant_id", "namespace", "idempotency_key", "db_set_version", "export_status", "exported_record_count", "non_claims"],
