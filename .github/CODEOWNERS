# ExoChain CODEOWNERS
# Maps code areas to council panel reviewers.
# All changes require at least one approval from the relevant panel.

# Default: Architecture panel
* @exochain/architecture

# Rust core — Architecture + Security panels
/crates/ @exochain/architecture @exochain/security

# Cryptographic code — Security panel required
/crates/exo-core/src/crypto.rs @exochain/security
/crates/exo-identity/ @exochain/security
