FROM node:20-alpine

ARG SERVICE

WORKDIR /app

# Copy workspace root
COPY demo/package.json ./

# Copy WASM package
COPY demo/packages/exochain-wasm ./packages/exochain-wasm

# Copy shared lib
COPY demo/packages/shared ./packages/shared

# Copy the specific service
COPY demo/services/${SERVICE} ./services/${SERVICE}

# Install dependencies
RUN npm install --workspace=services/${SERVICE}

WORKDIR /app/services/${SERVICE}

CMD ["node", "src/index.js"]
