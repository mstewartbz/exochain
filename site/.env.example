# EXOCHAIN site — environment variables
#
# In v0 the site uses a mock cookie session; no real OIDC client is wired.
# These are placeholders so that the v0.5 OIDC integration knows what to fill in.

EXO_NETWORK_MODE=alpha-testnet           # alpha-testnet | testnet | mainnet
EXO_GATEWAY_URL=                         # exo-gateway base URL once available
EXO_OIDC_ISSUER=                         # OIDC issuer URL (v0.5+)
EXO_OIDC_CLIENT_ID=                      # OIDC client id (v0.5+)
EXO_OIDC_CLIENT_SECRET=                  # OIDC client secret (v0.5+)
