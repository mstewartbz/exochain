# ════════════════════════════════════════════════════════════════
# Dockerfile.prod — Command Base production image
# Target: ARM64/aarch64 (NVIDIA DGX Spark, Ubuntu 24.04)
# Generated by Onyx (CTO) — 2026-04-04
#
# Key decisions:
#   - node:20-slim (Debian/glibc) — alpine WILL FAIL because
#     better-sqlite3 is a native C++ addon compiled against glibc
#   - Multi-stage build: builder compiles native addons, runtime
#     stage discards build tools (smaller image, smaller attack surface)
#   - tini as PID 1: reaps zombie processes from Claude CLI spawns
#     and handles SIGTERM correctly (Node.js does not without tini)
#   - entrypoint.sh: copies .claude.json auth from bind-mounted
#     host config directory on first boot
# ════════════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────────────
# Stage 1: Builder — compile native Node.js addons for ARM64
# ────────────────────────────────────────────────────────────────
FROM node:20-slim AS builder

# Build tools required for better-sqlite3 native compilation on ARM64
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    make \
    g++ \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install dependencies first (cached layer — only invalidated when
# package*.json changes, not on app code changes)
COPY package*.json ./
RUN npm ci

# Copy app source
COPY . .

# ────────────────────────────────────────────────────────────────
# Stage 2: Runtime — lean production image
# ────────────────────────────────────────────────────────────────
FROM node:20-slim AS runtime

# Runtime dependencies only:
#   curl   — healthcheck (docker-compose healthcheck command)
#   tini   — PID 1 init process (zombie reaping + SIGTERM handling)
#   sqlite3 — used by backup scripts if needed inside container
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    tini \
    sqlite3 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy compiled node_modules from builder stage
# This includes the ARM64-compiled better-sqlite3 .node binary
COPY --from=builder /app/node_modules ./node_modules

# Copy application code
COPY --from=builder /app .

# Create data directory (container-internal; actual data via bind mount)
RUN mkdir -p /data/backups

# ── Entrypoint script ────────────────────────────────────────────
# Handles Claude CLI auth on container startup:
#   1. Copies .claude.json from bind-mounted host config if not present
#   2. Falls back to backup in /root/.claude/backups/ if available
#   3. Starts the app server
RUN printf '#!/bin/sh\n\
set -e\n\
\n\
# Copy claude auth from host-mounted config if not yet present\n\
if [ ! -f /root/.claude.json ] && [ -f /host-home/.claude.json ]; then\n\
  cp /host-home/.claude.json /root/.claude.json\n\
  echo "[startup] Copied claude auth from host config"\n\
fi\n\
\n\
# Fallback: restore from backup directory\n\
if [ ! -f /root/.claude.json ]; then\n\
  LATEST=$(ls -t /root/.claude/backups/.claude.json.backup.* 2>/dev/null | head -1)\n\
  if [ -n "$LATEST" ]; then\n\
    cp "$LATEST" /root/.claude.json\n\
    echo "[startup] Restored claude auth from backup: $LATEST"\n\
  fi\n\
fi\n\
\n\
if [ ! -f /root/.claude.json ]; then\n\
  echo "[startup] WARNING: No claude auth found. Run: docker exec command-base claude auth login"\n\
fi\n\
\n\
exec node server.js\n' > /app/entrypoint.sh \
    && chmod +x /app/entrypoint.sh

EXPOSE 3000

# tini as PID 1:
#   - Reaps zombie processes created by Claude CLI subprocess spawns
#   - Passes SIGTERM to Node.js correctly (Node ignores SIGTERM as PID 1)
#   - Required for graceful container shutdown
ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["/app/entrypoint.sh"]
