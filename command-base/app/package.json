{
  "name": "the-team-dashboard",
  "version": "1.0.0",
  "description": "Local dashboard for The Team's DAG DB-backed CommandBase state",
  "main": "server.js",
  "scripts": {
    "test": "node --test",
    "test:coverage": "node --experimental-test-coverage --test-coverage-include=lib/commandbase-dagdb-adapter.js --test-coverage-include=lib/commandbase-db-factory.js --test-coverage-lines=90 --test commandbase-dagdb-adapter.test.js",
    "start": "node server.js",
    "test:upload-policy": "node lib/upload-policy.test.js",
    "audit:check": "npm audit --audit-level=high",
    "audit:fix": "npm audit fix --force --audit-level=high",
    "audit:report": "npm audit --json > audit-report.json && echo 'Audit report written to audit-report.json'",
    "audit:moderate": "npm audit --audit-level=moderate",
    "preinstall": "npm audit --audit-level=critical || true"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@exochain/exochain-wasm": "file:../../packages/exochain-wasm/wasm",
    "compression": "^1.8.1",
    "express": "^4.21.0",
    "multer": "^1.4.5-lts.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "better-sqlite3": "^12.8.0"
  }
}
