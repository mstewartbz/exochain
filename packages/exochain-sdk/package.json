{
  "name": "@exochain/sdk",
  "version": "0.1.0",
  "description": "EXOCHAIN SDK — constitutional governance fabric for AI and data sovereignty",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/exochain/exochain.git",
    "directory": "packages/exochain-sdk"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./identity": {
      "types": "./dist/identity/index.d.ts",
      "import": "./dist/identity/index.js"
    },
    "./consent": {
      "types": "./dist/consent/index.d.ts",
      "import": "./dist/consent/index.js"
    },
    "./governance": {
      "types": "./dist/governance/index.d.ts",
      "import": "./dist/governance/index.js"
    },
    "./authority": {
      "types": "./dist/authority/index.d.ts",
      "import": "./dist/authority/index.js"
    },
    "./crypto": {
      "types": "./dist/crypto/index.d.ts",
      "import": "./dist/crypto/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc",
    "test": "tsc -p tsconfig.test.json && node --test dist-test/test/*.test.js",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist dist-test"
  },
  "keywords": ["exochain", "constitutional", "governance", "did", "consent", "sdk", "ai-safety"],
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
