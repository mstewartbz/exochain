# Exochain environment — copy to .env (gitignored) before running
# `docker compose up` or the node binary locally. Nothing in this file is
# safe for production; all values MUST be rotated before any shared use.

# =============================================================================
# Postgres (used by docker-compose.yml) — REQUIRED for local dev
# =============================================================================
POSTGRES_DB=exochain
POSTGRES_USER=exochain
# DEV-ONLY password. Rotate before any non-local use.
POSTGRES_PASSWORD=replace-with-strong-dev-password

# =============================================================================
# Rust services — REQUIRED
# =============================================================================
DATABASE_URL=postgres://exochain:replace-with-strong-dev-password@localhost:5432/exochain
PORT=8080
# DEV-ONLY HMAC secret. Rotate for any non-local use. A real value should
# be 32+ bytes of randomness (`openssl rand -hex 32`).
JWT_SECRET=change-me-in-production
RUST_LOG=info

# =============================================================================
# LiveSafe sibling service (optional — docker-compose only)
# =============================================================================
LIVESAFE_JWT_SECRET=change-me-in-production

# =============================================================================
# Node entrypoint env vars (consumed by deploy/entrypoint.sh) — optional
# =============================================================================
# Directory inside the container/host where the node persists identity + DAG.
EXOCHAIN_DATA_DIR=/data
# Listen port for libp2p TCP + QUIC traffic. Default 4001.
P2P_PORT=4001
# Optional: join an existing network. e.g. seed1.exochain.io:4001
# SEED_ADDR=
# Set to "true" to run as a validator without an explicit validator set.
# IS_VALIDATOR=false
# Comma-separated list of validator DIDs; implies IS_VALIDATOR=true when set.
# VALIDATORS=
